@using System.Data
@model Proyecto_Integrador_DevOps.Models.QueryResultViewModel

@{
    bool isAdmin = Context.Session.GetString("IsAdmin") == "True";
    bool isEditMode = Model?.QueryReport != null && Model.QueryReport.ReportId > 0;
}

<style>
    body {
        background-color: #f4f6f9;
        font-family: 'Segoe UI', sans-serif;
    }

    .page-container {
        max-width: 1000px;
        margin: 40px auto;
        background: white;
        padding: 35px;
        border-radius: 14px;
        box-shadow: 0 8px 25px rgba(0,0,0,0.08);
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 25px;
    }

    h2 {
        margin: 0;
        font-weight: 600;
    }

    .btn-regresar {
        padding: 8px 16px;
        background-color: #6c757d;
        color: white;
        border-radius: 6px;
        text-decoration: none;
        font-size: 14px;
        transition: 0.2s;
    }

        .btn-regresar:hover {
            background-color: #5a6268;
        }

    .info-box {
        background-color: #f8f9fa;
        padding: 12px;
        border-radius: 6px;
        margin-bottom: 15px;
        font-size: 14px;
    }

    .form-group {
        margin-bottom: 18px;
    }

    label {
        font-weight: 600;
        display: block;
        margin-bottom: 6px;
        font-size: 14px;
    }

    select, textarea, input[type="text"] {
        width: 100%;
        padding: 10px;
        border-radius: 6px;
        border: 1px solid #ddd;
        font-size: 14px;
        transition: 0.2s;
    }

        select:focus, textarea:focus, input:focus {
            outline: none;
            border-color: #3498db;
            box-shadow: 0 0 0 2px rgba(52,152,219,0.1);
        }

    textarea {
        resize: vertical;
        font-family: Consolas, monospace;
        background-color: #f8f9fa;
    }

    .button-group {
        margin-top: 20px;
    }

    .btn-primary {
        background-color: #3498db;
        color: white;
    }

        .btn-primary:hover {
            background-color: #2980b9;
        }

    .btn-secondary {
        background-color: #2ecc71;
        color: white;
    }

        .btn-secondary:hover {
            background-color: #27ae60;
        }

    button {
        padding: 10px 18px;
        border-radius: 6px;
        border: none;
        cursor: pointer;
        font-size: 14px;
        margin-right: 10px;
        transition: 0.2s;
    }

    .error {
        background-color: #ffe6e6;
        color: #cc0000;
        padding: 10px;
        border-radius: 6px;
        margin-top: 15px;
    }

    .warning {
        background-color: #fff3cd;
        color: #856404;
        padding: 10px;
        border-radius: 6px;
        margin-top: 15px;
    }

    .result-container {
        margin-top: 40px;
        overflow-x: auto;
    }

    table {
        border-collapse: collapse;
        width: 100%;
        font-size: 14px;
    }

    th {
        background-color: #3498db;
        color: white;
        padding: 10px;
        text-align: left;
    }

    td {
        padding: 8px;
        border-bottom: 1px solid #eee;
    }

    tr:nth-child(even) {
        background-color: #f9f9f9;
    }

    tr:hover {
        background-color: #eef6ff;
    }
</style>

<div class="page-container">

    <div class="page-header">
        <h2>
            @(isEditMode
                        ? $"Editar Reporte: {Model!.QueryReport!.Name}"
                        : "Nuevo Reporte")
        </h2>

        <a asp-controller="Reports"
           asp-action="List"
           class="btn-regresar">
            ← Regresar
        </a>
    </div>

    @if (isEditMode)
    {
        <div class="info-box">
            <strong>ID:</strong> @Model!.QueryReport!.ReportId <br />
            <strong>Usuario creador:</strong> @Model.QueryReport.UserId <br />
            <strong>Fecha creación:</strong> @Model.QueryReport.CreatedAt
        </div>
    }

    <form method="post">

        <input type="hidden" asp-for="QueryReport.ReportId" />
        <input type="hidden" asp-for="QueryReport.UserId" />

        <div class="form-group">
            <label>Nombre del Reporte</label>
            <input asp-for="QueryReport.Name"
                   type="text"
                   readonly="@(isAdmin ? null : "readonly")" />
        </div>

        <div class="form-group">
            <label>Área</label>
            <select asp-for="QueryReport.Area"
                    disabled="@(isAdmin ? null : "disabled")">
                <option value=""> --- Selecciona área --- </option>
                <option value="Ventas">Ventas</option>
                <option value="Operaciones">Operaciones</option>
                <option value="Finanzas">Finanzas</option>
            </select>
        </div>

        <div class="form-group">
            <label>Base de datos</label>
            <select asp-for="QueryReport.ConnectionString"
                    disabled="@(isAdmin ? null : "disabled")">
                <option value=""> --- Selecciona una base --- </option>
                <option value="Clients">ClientsDb</option>
                <option value="Reservations">ReservationsDb</option>
                <option value="Costs">CostsDb</option>
            </select>
        </div>

        <div class="form-group">
            <label>Query</label>
            <textarea asp-for="QueryReport.Query"
                      rows="8"
                      readonly="@(isAdmin ? null : "readonly")"></textarea>
        </div>

        <div class="button-group">

            <button type="submit"
                    class="btn-primary"
                    formaction="@Url.Action("Execute", "Home")">
                Ejecutar
            </button>

            @if (isAdmin)
            {
                if (isEditMode)
                {
                    <button type="submit"
                            class="btn-secondary"
                            formaction="@Url.Action("Update", "Reports")">
                        Actualizar Reporte
                    </button>
                }
                else
                {
                    <button type="submit"
                            class="btn-secondary"
                            formaction="@Url.Action("Create", "Reports")">
                        Crear Reporte
                    </button>
                }
            }

        </div>

    </form>

    @if (!string.IsNullOrEmpty(Model?.ErrorMessage))
    {
        <div class="error">@Model.ErrorMessage</div>
    }

    @if (Model?.ErrorMessages != null && Model.ErrorMessages.Any())
    {
        <div class="error">
            <ul>
                @foreach (var error in Model.ErrorMessages)
                {
                    <li>@error</li>
                }
            </ul>
        </div>
    }

    @if (!string.IsNullOrEmpty(Model?.WarningMessage))
    {
        <div class="warning">@Model.WarningMessage</div>
    }

    @if (Model?.Result != null && Model.Result.Rows.Count > 0)
    {
        <div class="result-container">
            <table>
                <thead>
                    <tr>
                        @foreach (DataColumn col in Model.Result.Columns)
                        {
                            <th>@col.ColumnName</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (DataRow row in Model.Result.Rows)
                    {
                        <tr>
                            @foreach (var item in row.ItemArray)
                            {
                                <td>@(item == DBNull.Value ? "NULL" : item)</td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

</div>